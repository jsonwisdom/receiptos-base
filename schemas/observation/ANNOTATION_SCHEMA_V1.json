{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jsonwisdom.dev/schemas/observation/ANNOTATION_SCHEMA_V1.json",
  "title": "Annotation Schema V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "annotation_id",
    "authority",
    "referenced_capture_ids",
    "annotation_type",
    "claim_text",
    "confidence_level",
    "evidence_basis",
    "falsifiable_prediction",
    "expected_observation",
    "failure_condition",
    "limitation",
    "created_by",
    "created_at_utc"
  ],
  "properties": {
    "annotation_id": { "type": "string", "minLength": 1 },
    "authority": { "const": false },
    "referenced_capture_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "annotation_type": {
      "type": "string",
      "enum": ["hypothesis", "interpretation", "discrepancy", "prediction", "limitation"]
    },
    "claim_text": { "type": "string", "minLength": 1 },
    "confidence_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "evidence_basis": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "falsifiable_prediction": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "expected_observation": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "failure_condition": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "limitation": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "created_by": { "type": "string", "minLength": 1 },
    "created_at_utc": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "annotation_type": { "enum": ["hypothesis", "prediction"] } },
        "required": ["annotation_type"]
      },
      "then": {
        "properties": {
          "falsifiable_prediction": { "type": "string", "minLength": 1 },
          "expected_observation": { "type": "string", "minLength": 1 },
          "failure_condition": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "annotation_type": { "enum": ["interpretation", "discrepancy"] } },
        "required": ["annotation_type"]
      },
      "then": {
        "properties": {
          "limitation": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "falsifiable_prediction": { "type": "null" } },
        "required": ["falsifiable_prediction"]
      },
      "then": {
        "properties": {
          "limitation": { "type": "string", "minLength": 1 }
        }
      }
    }
  ]
}
