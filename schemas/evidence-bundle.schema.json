{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReceiptOS Evidence Bundle",
  "type": "object",
  "required": [
    "rosId",
    "version",
    "artifact",
    "publication",
    "evidence",
    "signature",
    "verificationScript",
    "timestamp",
    "verifier"
  ],
  "definitions": {
    "nonPlaceholderString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!REPLACE_WITH_).+"
    },
    "sha256": {
      "type": "string",
      "pattern": "^(?!REPLACE_WITH_)[0-9a-f]{64}$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^(?!REPLACE_WITH_)[0-9a-f]{40}$"
    },
    "hex64With0x": {
      "type": "string",
      "pattern": "^(?!REPLACE_WITH_)0x[0-9a-fA-F]{64}$"
    },
    "address": {
      "type": "string",
      "pattern": "^(?!REPLACE_WITH_)0x[0-9a-fA-F]{40}$"
    }
  },
  "properties": {
    "rosId": {
      "type": "string",
      "pattern": "^ROS-[0-9]{4}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9a-zA-Z.-]+)?$"
    },
    "artifact": {
      "type": "object",
      "required": ["name", "digest", "size"],
      "properties": {
        "name": { "$ref": "#/definitions/nonPlaceholderString" },
        "digest": { "$ref": "#/definitions/sha256" },
        "size": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "publication": {
      "type": "object",
      "required": ["repository", "commit", "tag", "timestamp"],
      "properties": {
        "repository": { "type": "string", "format": "uri" },
        "commit": { "$ref": "#/definitions/gitCommit" },
        "tag": {
          "type": "string",
          "pattern": "^v?\\d+\\.\\d+\\.\\d+(-[0-9a-zA-Z.-]+)?$"
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["eas_uid", "chain", "zora_coin"],
      "properties": {
        "eas_uid": { "$ref": "#/definitions/hex64With0x" },
        "chain": { "type": "string", "const": "base" },
        "zora_coin": { "$ref": "#/definitions/address" },
        "ipfs_cid": { "$ref": "#/definitions/nonPlaceholderString" }
      },
      "additionalProperties": false
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "signer", "key_id", "sig"],
      "properties": {
        "algorithm": { "type": "string", "const": "ed25519" },
        "signer": { "$ref": "#/definitions/nonPlaceholderString" },
        "key_id": { "$ref": "#/definitions/nonPlaceholderString" },
        "sig": {
          "type": "string",
          "pattern": "^(?!REPLACE_WITH_)[A-Za-z0-9+/=]+$"
        }
      },
      "additionalProperties": false
    },
    "verificationScript": {
      "type": "object",
      "required": ["path", "algorithm", "digest"],
      "properties": {
        "path": { "type": "string", "const": "scripts/verify-evidence-bundle.py" },
        "algorithm": { "type": "string", "const": "sha256" },
        "digest": { "$ref": "#/definitions/sha256" }
      },
      "additionalProperties": false
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "verifier": {
      "type": "object",
      "required": ["name", "version", "commit"],
      "properties": {
        "name": { "type": "string", "const": "receiptos-verifier" },
        "version": { "$ref": "#/definitions/nonPlaceholderString" },
        "commit": { "$ref": "#/definitions/gitCommit" }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": ["authority"],
      "properties": {
        "authority": { "type": "boolean", "const": false }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
