{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jsonwisdom/receiptos-base/schemas/receipt.schema.json",
  "title": "ReceiptOS Process Receipt Schema v0.1",
  "description": "Schema for ReceiptOS process-provenance receipts. This validates evidence about repository artifacts and replay steps, not legal truth or institutional authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "receipt_type",
    "schema_version",
    "repo",
    "commit_sha",
    "artifact_path",
    "artifact_blob_sha",
    "artifact_sha256",
    "observed_at",
    "verification_method",
    "authority",
    "mutable_context_excluded"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for this receipt."
    },
    "receipt_type": {
      "type": "string",
      "enum": [
        "PROCESS_PROVENANCE",
        "COMMIT_BOUND_ARTIFACT",
        "REPLAY_RESULT",
        "EXTERNAL_WITNESS"
      ]
    },
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "artifact_blob_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$",
      "description": "Git blob SHA for the artifact content."
    },
    "artifact_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA256 of the artifact bytes or canonical serialized artifact."
    },
    "tree_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Optional SHA256 over a deterministic git ls-tree output or equivalent replay surface."
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "verification_method": {
      "type": "string",
      "minLength": 1
    },
    "witnesses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["witness_type", "claim", "authority"],
        "properties": {
          "witness_type": {
            "type": "string",
            "enum": ["LOCAL_GIT", "GITHUB_API", "EXTERNAL_MODEL", "USER_TRANSCRIPT", "OTHER"]
          },
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "authority": {
            "type": "boolean",
            "const": false
          }
        }
      },
      "default": []
    },
    "authority": {
      "type": "boolean",
      "const": false,
      "description": "ReceiptOS receipts do not establish legal truth or institutional authority."
    },
    "mutable_context_excluded": {
      "type": "boolean",
      "const": true,
      "description": "Mutable repository metadata is excluded from SHA-bound proof unless separately captured and committed."
    }
  }
}
