{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://receiptos.local/schemas/receipt.schema.json",
  "title": "ReceiptOS Receipt v0.1",
  "type": "object",
  "required": [
    "receipt_version",
    "receipt_type",
    "authority",
    "engine_id",
    "engine_version",
    "replay_invariants",
    "timestamp",
    "input_hash",
    "output_hash",
    "status"
  ],
  "properties": {
    "receipt_version": { "const": "0.1" },
    "receipt_type": {
      "enum": [
        "manifest_verify",
        "tree_hash",
        "schema_validate",
        "invariants_check",
        "replay_run",
        "replay_verify"
      ]
    },
    "authority": { "const": false },
    "engine_id": { "const": "receiptos-replay-engine" },
    "engine_version": { "const": "0.1" },
    "replay_invariants": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "input_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "output_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "status": { "enum": ["PASS", "FAIL"] },
    "exit_code": { "type": "integer", "minimum": 0, "maximum": 9 },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
